# ticketlab deployment env — copy to .env on the VM and fill in. .env is gitignored.
TICKETLAB_HOST=0.0.0.0
TICKETLAB_PORT=8090
TICKETLAB_DB=/data/ticketlab.db

# Ollama customer/grader (falls back to scripted mode per turn if unreachable).
TICKETLAB_OLLAMA=1
TICKETLAB_OLLAMA_URL=http://192.168.0.127:11434
TICKETLAB_OLLAMA_MODEL=llama3.1:8b-instruct-q5_K_M
